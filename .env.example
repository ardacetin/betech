APP_ENV=production
APP_DEBUG=false
DISPLAY_ERROR_DETAILS=false
APP_URL=https://your-domain.example

# Comma-separated trusted proxy IPs/CIDRs, or * to trust Cloudflare/WAF forwarded headers.
TRUSTED_PROXIES=*

AUTH_DRIVER=local

DB_TYPE=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4

# SMTP mail delivery (ticket notifications)
MAIL_ENABLED=true
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Betech ITMS
# Optional comma-separated IT support inbox(es). Operational user emails are also notified.
MAIL_SUPPORT_TO=
