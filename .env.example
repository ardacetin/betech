APP_ENV=production
APP_DEBUG=false
DISPLAY_ERROR_DETAILS=false
APP_URL=https://your-domain.example

# Comma-separated trusted proxy IPs/CIDRs, or * to trust Cloudflare/WAF forwarded headers.
TRUSTED_PROXIES=*

AUTH_DRIVER=local

# Optional LDAP login suffix appended to bare usernames (e.g. @domain.edu.tr).
LDAP_ACCOUNT_SUFFIX=

DB_TYPE=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4

# SMTP / ticket notification settings are configured in Admin UI:
# Settings -> SMTP Ayarları
# Optional .env overrides for CLI health scanner / automation:
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Betech ITMS

# Telegram alerts for daily health scanner (php cli.php notify:health_scan)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudflare R2 (S3-compatible) remote database backups
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=beykoz-betech
