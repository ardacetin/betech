APP_ENV=local
APP_DEBUG=true
DISPLAY_ERROR_DETAILS=true
APP_URL=https://your-domain.example

# Comma-separated trusted proxy IPs/CIDRs, or * to trust Cloudflare/WAF forwarded headers.
TRUSTED_PROXIES=*

AUTH_DRIVER=local

# Optional LDAP login suffix appended to bare usernames (e.g. @domain.edu.tr).
LDAP_ACCOUNT_SUFFIX=

DB_TYPE=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4

# SMTP / ticket notification settings are configured in Admin UI:
# Settings -> SMTP Ayarları
# Optional .env overrides for CLI health scanner / automation:
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
# Sender address. When empty, the first "Destek Gelen Kutusu" support inbox address is used.
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Betech ITMS

# Inbound help desk email fetching (php cli.php mail:fetch_inbox)
# Requires PHP ext-imap. Schedule via cron every 5-15 minutes.
MAIL_IMAP_ENABLED=
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
MAIL_IMAP_ENCRYPTION=ssl
MAIL_IMAP_USERNAME=
MAIL_IMAP_PASSWORD=
MAIL_IMAP_MAILBOX=INBOX

# Telegram alerts for daily health scanner (php cli.php notify:health_scan)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudflare R2 (S3-compatible) remote database backups
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=beykoz-betech
